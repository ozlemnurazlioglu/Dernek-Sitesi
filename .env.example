# ─────────────────────────────────────────────────────────────
# DERNEK SİTESİ — ÖRNEK ENV DEĞİŞKENLERİ
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun.
# Vercel'de ise "Project Settings → Environment Variables" altına ekleyin.
# ─────────────────────────────────────────────────────────────

# ─── VERİTABANI (TiDB / PlanetScale / Aiven / herhangi bir uzak MySQL) ───
# Tek satır URL formatı (ÖNERİLEN — production için zorunlu):
DATABASE_URL=mysql://USER:PASSWORD@HOST:4000/DB_NAME

# Production'da TLS (SSL) varsayılan olarak AÇIK; istisna gerekirse:
# DATABASE_SSL=true   # zorla aç
# DATABASE_SSL=false  # zorla kapat
# Connection pool boyutu (serverless için 5 önerilir):
# DB_POOL_SIZE=5

# Yerel geliştirme için (DATABASE_URL boşsa kullanılır):
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=dernek

# ─── OTURUM (cookie imzası) ────────────────────────────────────
# 32+ karakter rastgele dizi. Production'da MUTLAKA değiştirin:
SESSION_SECRET=change-me-to-a-long-random-string

# ─── DOSYA YÜKLEME (Vercel Blob) ───────────────────────────────
# Vercel'de Blob storage bağladığınızda otomatik gelir.
# Yerel geliştirmede boş bırakırsanız dosyalar /public/uploads altına yazılır.
# BLOB_READ_WRITE_TOKEN=
