# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# Örnek env dosyası repoda kalsın — gerçek değerler içermez
!.env.example

# user uploads (admin paneli üzerinden yüklenen dosyalar)
/public/uploads/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Geliştirme/test sırasında repo köküne kaydedilen ekran görüntüleri
/*.png
# Playwright MCP çıktıları (otomatik testler)
.playwright-mcp/

# cPanel'e yüklemek üzere üretilen build tarball'ı (her release için yeniden üretilir)
/next-build.tar.gz
/migration-*.tar.gz

# Geçici commit mesajı dosyası (git commit -F .commit-msg.txt için)
/.commit-msg.txt

.vercel
